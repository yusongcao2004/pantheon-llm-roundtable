# Pantheon environment template
# Copy this file to .env and fill in local values.
# Never commit .env.

# LLM provider API keys
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_AI_API_KEY=
DOUBAO_API_KEY=

# Telegram bot tokens: one bot identity per public participant
TELEGRAM_BOT_TOKEN_CHATGPT=
TELEGRAM_BOT_TOKEN_DEEPSEEK=
TELEGRAM_BOT_TOKEN_GEMINI=
TELEGRAM_BOT_TOKEN_DOUBAO=

# Telegram group configuration
TELEGRAM_GROUP_CHAT_ID=

# Optional: restrict operational commands to one Telegram user ID.
# Leave empty to allow anyone in the configured group to issue commands.
TELEGRAM_GOD_USER_ID=
